APP_PORT=8080

POSTGRES_DB=calories_detect
POSTGRES_USER=calories_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

DB_HOST=localhost
DB_PORT=5433
DB_NAME=calories_detect
DB_USERNAME=calories_user
DB_PASSWORD=change-me

# Use a random value with at least 32 bytes in production.
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# GitHub Actions / VPS deployment secrets.
# Add these in GitHub repository Settings > Secrets and variables > Actions.
VPS_HOST=your-vps-ip-or-domain
VPS_USER=your-vps-ssh-user
VPS_SSH_PORT=22
VPS_SSH_KEY=your-private-ssh-key
